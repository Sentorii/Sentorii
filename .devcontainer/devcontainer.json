{
    "name": "Sentorii-dev",
    "image": "mcr.microsoft.com/devcontainers/rust:1-bullseye",
    "features": {
        "ghcr.io/devcontainers/features/node:1": {},
		"ghcr.io/guiyomh/features/just:0": {}
    },
    "postCreateCommand": "rustup component add rustfmt clippy && cargo install bacon --locked && cargo install cargo-nextest --locked",
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
				"serayuzgur.crates",
				"tamasfe.even-better-toml"
            ]
        }
    }
}